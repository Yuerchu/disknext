# ============================================================
# DiskNext Server 环境变量
# ============================================================
# 复制此文件为 .env 后按需修改
#   cp .env.example .env

# ------------------------------------------------------------
# 运行模式
# ------------------------------------------------------------

# 运行模式: master (主机) / slave (从机)
MODE=master

# 调试模式 (true / false)
DEBUG=false

# ------------------------------------------------------------
# 数据库
# ------------------------------------------------------------

# 默认使用项目目录下的 SQLite
# DATABASE_URL=sqlite+aiosqlite:///disknext.db

# PostgreSQL (推荐)
DATABASE_URL=postgresql+asyncpg://disknext:disknext@localhost:5432/disknext

# ------------------------------------------------------------
# Redis (可选 — 未配置时部分即时功能会降级)
# ------------------------------------------------------------

# Redis 主机地址 (留空则不启用 Redis)
REDIS_URL=localhost

# Redis 端口 (默认 6379)
REDIS_PORT=6379

# Redis 密码 (无密码时留空)
REDIS_PASSWORD=

# Redis 数据库索引 (默认 0)
REDIS_DB=0

# Redis 协议版本 (默认 3)
REDIS_PROTOCOL=3

# ------------------------------------------------------------
# Enterprise Edition (可选)
# ------------------------------------------------------------

# 许可证内容 (可选 — 未设置则从项目根目录的 license.key 文件读取)
# LICENSE_KEY=
