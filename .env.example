# ============================================================
# DiskNext Server 环境变量
# ============================================================
# 复制此文件为 .env 后按需修改
#   cp .env.example .env

# ------------------------------------------------------------
# 运行模式
# ------------------------------------------------------------

# 运行模式: master (主机) / slave (从机)
MODE=master

# 调试模式 (true / false)
DEBUG=false

# ------------------------------------------------------------
# 数据库（必需，仅支持 PostgreSQL）
# ------------------------------------------------------------

# PostgreSQL 连接 URL，必须使用 asyncpg 驱动
DATABASE_URL=postgresql+asyncpg://disknext:disknext@localhost:5432/disknext

# ------------------------------------------------------------
# Redis（必需，强制要求）
# ------------------------------------------------------------

# Redis 完整连接 URL，格式：redis://[:password@]host:port/db
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# JWT 签名密钥（必需，最少 32 字符）
# ------------------------------------------------------------

# 建议使用 64 位以上的随机十六进制字符串
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ------------------------------------------------------------
# 测试环境（运行 pytest 时必需）
# ------------------------------------------------------------

# 测试数据库：db 名必须包含 test 或 dev，防止误伤生产库
# TEST_DATABASE_URL=postgresql+asyncpg://disknext:disknext@localhost:5432/disknext_test

# 测试 Redis：db index 必须 >= 1，防止 flushdb 清掉生产数据
# TEST_REDIS_URL=redis://localhost:6379/15